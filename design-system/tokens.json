{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "K-Marketing Design Tokens — W3C DTCG Format — 3 Livelli",

  "primitive": {
    "$description": "Layer 1 — Raw values, no semantic meaning",

    "color": {
      "navy": {
        "50":  { "$type": "color", "$value": "#e8e8f0" },
        "100": { "$type": "color", "$value": "#c5c6d8" },
        "200": { "$type": "color", "$value": "#9294b8" },
        "300": { "$type": "color", "$value": "#5f6298" },
        "400": { "$type": "color", "$value": "#333780" },
        "500": { "$type": "color", "$value": "#1a1d5c" },
        "600": { "$type": "color", "$value": "#101340" },
        "700": { "$type": "color", "$value": "#0a0d30" },
        "800": { "$type": "color", "$value": "#060724" },
        "900": { "$type": "color", "$value": "#03041a" },
        "950": { "$type": "color", "$value": "#020312" }
      },
      "orange": {
        "50":  { "$type": "color", "$value": "#fff3e6" },
        "100": { "$type": "color", "$value": "#ffe0bf" },
        "200": { "$type": "color", "$value": "#ffcc99" },
        "300": { "$type": "color", "$value": "#ffaa55" },
        "400": { "$type": "color", "$value": "#ff8833" },
        "500": { "$type": "color", "$value": "#ff6700" },
        "600": { "$type": "color", "$value": "#e05b00" },
        "700": { "$type": "color", "$value": "#b84a00" },
        "800": { "$type": "color", "$value": "#8a3800" },
        "900": { "$type": "color", "$value": "#5c2500" }
      },
      "gray": {
        "50":  { "$type": "color", "$value": "#f8f8f8" },
        "100": { "$type": "color", "$value": "#edeced" },
        "200": { "$type": "color", "$value": "#d9d8d9" },
        "300": { "$type": "color", "$value": "#b8b7b8" },
        "400": { "$type": "color", "$value": "#8a898a" },
        "500": { "$type": "color", "$value": "#6b6a6b" },
        "600": { "$type": "color", "$value": "#4a494a" },
        "700": { "$type": "color", "$value": "#333233" },
        "800": { "$type": "color", "$value": "#1f1e1f" },
        "900": { "$type": "color", "$value": "#121112" }
      },
      "white": { "$type": "color", "$value": "#ffffff" },
      "black": { "$type": "color", "$value": "#000000" },
      "success": { "$type": "color", "$value": "#10b981" },
      "warning": { "$type": "color", "$value": "#f59e0b" },
      "error":   { "$type": "color", "$value": "#ef4444" },
      "info":    { "$type": "color", "$value": "#3b82f6" }
    },

    "font": {
      "family": {
        "primary": { "$type": "fontFamily", "$value": "'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif" },
        "mono":    { "$type": "fontFamily", "$value": "'JetBrains Mono', 'Fira Code', monospace" }
      },
      "weight": {
        "regular":  { "$type": "fontWeight", "$value": 400 },
        "medium":   { "$type": "fontWeight", "$value": 500 },
        "semibold": { "$type": "fontWeight", "$value": 600 },
        "bold":     { "$type": "fontWeight", "$value": 700 },
        "extrabold":{ "$type": "fontWeight", "$value": 800 }
      },
      "size": {
        "xs":   { "$type": "dimension", "$value": "0.75rem" },
        "sm":   { "$type": "dimension", "$value": "0.875rem" },
        "base": { "$type": "dimension", "$value": "1rem" },
        "lg":   { "$type": "dimension", "$value": "1.125rem" },
        "xl":   { "$type": "dimension", "$value": "1.25rem" },
        "2xl":  { "$type": "dimension", "$value": "1.5rem" },
        "3xl":  { "$type": "dimension", "$value": "1.875rem" },
        "4xl":  { "$type": "dimension", "$value": "2.25rem" },
        "5xl":  { "$type": "dimension", "$value": "3rem" },
        "6xl":  { "$type": "dimension", "$value": "3.75rem" },
        "7xl":  { "$type": "dimension", "$value": "4.5rem" }
      },
      "lineHeight": {
        "tight":   { "$type": "number", "$value": 1.1 },
        "snug":    { "$type": "number", "$value": 1.25 },
        "normal":  { "$type": "number", "$value": 1.5 },
        "relaxed": { "$type": "number", "$value": 1.75 }
      },
      "letterSpacing": {
        "tighter": { "$type": "dimension", "$value": "-0.03em" },
        "tight":   { "$type": "dimension", "$value": "-0.02em" },
        "normal":  { "$type": "dimension", "$value": "0" },
        "wide":    { "$type": "dimension", "$value": "0.05em" },
        "wider":   { "$type": "dimension", "$value": "0.1em" }
      }
    },

    "spacing": {
      "1":  { "$type": "dimension", "$value": "0.25rem" },
      "2":  { "$type": "dimension", "$value": "0.5rem" },
      "3":  { "$type": "dimension", "$value": "0.75rem" },
      "4":  { "$type": "dimension", "$value": "1rem" },
      "5":  { "$type": "dimension", "$value": "1.25rem" },
      "6":  { "$type": "dimension", "$value": "1.5rem" },
      "8":  { "$type": "dimension", "$value": "2rem" },
      "10": { "$type": "dimension", "$value": "2.5rem" },
      "12": { "$type": "dimension", "$value": "3rem" },
      "16": { "$type": "dimension", "$value": "4rem" },
      "20": { "$type": "dimension", "$value": "5rem" },
      "24": { "$type": "dimension", "$value": "6rem" },
      "32": { "$type": "dimension", "$value": "8rem" }
    },

    "radius": {
      "sm":   { "$type": "dimension", "$value": "6px" },
      "md":   { "$type": "dimension", "$value": "8px" },
      "lg":   { "$type": "dimension", "$value": "12px" },
      "xl":   { "$type": "dimension", "$value": "16px" },
      "2xl":  { "$type": "dimension", "$value": "20px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    },

    "shadow": {
      "sm":   { "$type": "shadow", "$value": "0 1px 2px rgba(6,7,36,0.06)" },
      "md":   { "$type": "shadow", "$value": "0 4px 12px rgba(6,7,36,0.08)" },
      "lg":   { "$type": "shadow", "$value": "0 12px 32px rgba(6,7,36,0.12)" },
      "xl":   { "$type": "shadow", "$value": "0 24px 48px rgba(6,7,36,0.16)" },
      "glow-orange": { "$type": "shadow", "$value": "0 0 40px rgba(255,103,0,0.25)" },
      "glow-navy":   { "$type": "shadow", "$value": "0 0 40px rgba(6,7,36,0.4)" }
    },

    "duration": {
      "fast":   { "$type": "duration", "$value": "150ms" },
      "base":   { "$type": "duration", "$value": "300ms" },
      "slow":   { "$type": "duration", "$value": "500ms" },
      "slower": { "$type": "duration", "$value": "700ms" }
    },

    "easing": {
      "default":  { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
      "in":       { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] },
      "out":      { "$type": "cubicBezier", "$value": [0, 0, 0.2, 1] },
      "in-out":   { "$type": "cubicBezier", "$value": [0.4, 0, 0.6, 1] },
      "spring":   { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1] }
    },

    "breakpoint": {
      "sm":  { "$type": "dimension", "$value": "480px" },
      "md":  { "$type": "dimension", "$value": "768px" },
      "lg":  { "$type": "dimension", "$value": "1024px" },
      "xl":  { "$type": "dimension", "$value": "1280px" },
      "2xl": { "$type": "dimension", "$value": "1440px" }
    }
  },

  "semantic": {
    "$description": "Layer 2 — Meaning-based tokens (reference primitives)",

    "color": {
      "dark": {
        "$description": "Dark theme (default)",
        "bg-primary":     { "$type": "color", "$value": "{primitive.color.navy.800}" },
        "bg-secondary":   { "$type": "color", "$value": "{primitive.color.navy.700}" },
        "bg-elevated":    { "$type": "color", "$value": "{primitive.color.navy.600}" },
        "bg-surface":     { "$type": "color", "$value": "#0d0f2e" },
        "text-primary":   { "$type": "color", "$value": "{primitive.color.gray.100}" },
        "text-secondary": { "$type": "color", "$value": "rgba(237,236,237,0.7)" },
        "text-muted":     { "$type": "color", "$value": "rgba(237,236,237,0.5)" },
        "text-accent":    { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "border-subtle":  { "$type": "color", "$value": "rgba(237,236,237,0.08)" },
        "border-default": { "$type": "color", "$value": "rgba(237,236,237,0.12)" },
        "border-strong":  { "$type": "color", "$value": "rgba(237,236,237,0.2)" },
        "interactive":    { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "interactive-hover":  { "$type": "color", "$value": "{primitive.color.orange.400}" },
        "interactive-active": { "$type": "color", "$value": "{primitive.color.orange.600}" }
      },
      "light": {
        "$description": "Light theme",
        "bg-primary":     { "$type": "color", "$value": "{primitive.color.gray.100}" },
        "bg-secondary":   { "$type": "color", "$value": "{primitive.color.white}" },
        "bg-elevated":    { "$type": "color", "$value": "{primitive.color.white}" },
        "bg-surface":     { "$type": "color", "$value": "{primitive.color.gray.50}" },
        "text-primary":   { "$type": "color", "$value": "{primitive.color.navy.800}" },
        "text-secondary": { "$type": "color", "$value": "{primitive.color.gray.500}" },
        "text-muted":     { "$type": "color", "$value": "{primitive.color.gray.400}" },
        "text-accent":    { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "border-subtle":  { "$type": "color", "$value": "rgba(6,7,36,0.06)" },
        "border-default": { "$type": "color", "$value": "rgba(6,7,36,0.1)" },
        "border-strong":  { "$type": "color", "$value": "rgba(6,7,36,0.2)" },
        "interactive":    { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "interactive-hover":  { "$type": "color", "$value": "{primitive.color.orange.600}" },
        "interactive-active": { "$type": "color", "$value": "{primitive.color.orange.700}" }
      }
    },

    "typography": {
      "hero": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "clamp(2.5rem, 5vw, 4.5rem)",
          "fontWeight": "{primitive.font.weight.bold}",
          "lineHeight": "{primitive.font.lineHeight.tight}",
          "letterSpacing": "{primitive.font.letterSpacing.tighter}"
        }
      },
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "clamp(2rem, 4vw, 3.75rem)",
          "fontWeight": "{primitive.font.weight.bold}",
          "lineHeight": "{primitive.font.lineHeight.tight}",
          "letterSpacing": "{primitive.font.letterSpacing.tight}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "clamp(1.5rem, 3vw, 2.25rem)",
          "fontWeight": "{primitive.font.weight.bold}",
          "lineHeight": "{primitive.font.lineHeight.snug}",
          "letterSpacing": "{primitive.font.letterSpacing.tight}"
        }
      },
      "h3": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "clamp(1.25rem, 2vw, 1.5rem)",
          "fontWeight": "{primitive.font.weight.semibold}",
          "lineHeight": "{primitive.font.lineHeight.snug}",
          "letterSpacing": "{primitive.font.letterSpacing.normal}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "{primitive.font.size.base}",
          "fontWeight": "{primitive.font.weight.regular}",
          "lineHeight": "{primitive.font.lineHeight.normal}",
          "letterSpacing": "{primitive.font.letterSpacing.normal}"
        }
      },
      "body-lg": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "{primitive.font.size.lg}",
          "fontWeight": "{primitive.font.weight.regular}",
          "lineHeight": "{primitive.font.lineHeight.relaxed}",
          "letterSpacing": "{primitive.font.letterSpacing.normal}"
        }
      },
      "caption": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "{primitive.font.size.sm}",
          "fontWeight": "{primitive.font.weight.medium}",
          "lineHeight": "{primitive.font.lineHeight.normal}",
          "letterSpacing": "{primitive.font.letterSpacing.wide}"
        }
      },
      "overline": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.primary}",
          "fontSize": "{primitive.font.size.xs}",
          "fontWeight": "{primitive.font.weight.semibold}",
          "lineHeight": "{primitive.font.lineHeight.normal}",
          "letterSpacing": "{primitive.font.letterSpacing.wider}",
          "textTransform": "uppercase"
        }
      },
      "code": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.font.family.mono}",
          "fontSize": "{primitive.font.size.sm}",
          "fontWeight": "{primitive.font.weight.regular}",
          "lineHeight": "{primitive.font.lineHeight.normal}"
        }
      }
    },

    "layout": {
      "container-max":  { "$type": "dimension", "$value": "1280px" },
      "container-px":   { "$type": "dimension", "$value": "clamp(20px, 5vw, 48px)" },
      "section-py":     { "$type": "dimension", "$value": "clamp(80px, 10vw, 140px)" },
      "section-py-sm":  { "$type": "dimension", "$value": "clamp(48px, 6vw, 80px)" },
      "card-gap":       { "$type": "dimension", "$value": "{primitive.spacing.8}" },
      "grid-gap":       { "$type": "dimension", "$value": "{primitive.spacing.6}" }
    }
  },

  "component": {
    "$description": "Layer 3 — Component-specific tokens",

    "button": {
      "primary": {
        "bg":           { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "bg-hover":     { "$type": "color", "$value": "{primitive.color.orange.400}" },
        "bg-active":    { "$type": "color", "$value": "{primitive.color.orange.600}" },
        "text":         { "$type": "color", "$value": "{primitive.color.white}" },
        "radius":       { "$type": "dimension", "$value": "{primitive.radius.md}" },
        "shadow":       { "$type": "shadow", "$value": "{primitive.shadow.glow-orange}" },
        "px":           { "$type": "dimension", "$value": "{primitive.spacing.6}" },
        "py":           { "$type": "dimension", "$value": "{primitive.spacing.3}" },
        "font-size":    { "$type": "dimension", "$value": "{primitive.font.size.base}" },
        "font-weight":  { "$type": "fontWeight", "$value": "{primitive.font.weight.semibold}" }
      },
      "secondary": {
        "bg":           { "$type": "color", "$value": "transparent" },
        "border":       { "$type": "color", "$value": "{semantic.color.dark.border-strong}" },
        "text-dark":    { "$type": "color", "$value": "{primitive.color.gray.100}" },
        "text-light":   { "$type": "color", "$value": "{primitive.color.navy.800}" },
        "radius":       { "$type": "dimension", "$value": "{primitive.radius.md}" }
      },
      "ghost": {
        "bg":           { "$type": "color", "$value": "transparent" },
        "text-dark":    { "$type": "color", "$value": "{primitive.color.orange.400}" },
        "text-light":   { "$type": "color", "$value": "{primitive.color.orange.600}" },
        "bg-hover-dark":  { "$type": "color", "$value": "rgba(255,103,0,0.1)" },
        "bg-hover-light": { "$type": "color", "$value": "rgba(255,103,0,0.08)" }
      },
      "size": {
        "sm": { "px": { "$type": "dimension", "$value": "{primitive.spacing.4}" }, "py": { "$type": "dimension", "$value": "{primitive.spacing.2}" }, "font-size": { "$type": "dimension", "$value": "{primitive.font.size.sm}" } },
        "md": { "px": { "$type": "dimension", "$value": "{primitive.spacing.6}" }, "py": { "$type": "dimension", "$value": "{primitive.spacing.3}" }, "font-size": { "$type": "dimension", "$value": "{primitive.font.size.base}" } },
        "lg": { "px": { "$type": "dimension", "$value": "{primitive.spacing.8}" }, "py": { "$type": "dimension", "$value": "{primitive.spacing.4}" }, "font-size": { "$type": "dimension", "$value": "{primitive.font.size.lg}" } }
      }
    },

    "card": {
      "dark": {
        "bg":       { "$type": "color", "$value": "#0d0f2e" },
        "bg-hover": { "$type": "color", "$value": "#111338" },
        "border":   { "$type": "color", "$value": "rgba(237,236,237,0.08)" },
        "border-hover": { "$type": "color", "$value": "{primitive.color.orange.500}" }
      },
      "light": {
        "bg":       { "$type": "color", "$value": "{primitive.color.white}" },
        "bg-hover": { "$type": "color", "$value": "{primitive.color.gray.50}" },
        "border":   { "$type": "color", "$value": "rgba(6,7,36,0.08)" },
        "border-hover": { "$type": "color", "$value": "{primitive.color.orange.500}" }
      },
      "radius":   { "$type": "dimension", "$value": "{primitive.radius.xl}" },
      "padding":  { "$type": "dimension", "$value": "{primitive.spacing.6}" },
      "shadow":   { "$type": "shadow", "$value": "{primitive.shadow.md}" }
    },

    "input": {
      "dark": {
        "bg":           { "$type": "color", "$value": "rgba(237,236,237,0.05)" },
        "border":       { "$type": "color", "$value": "rgba(237,236,237,0.12)" },
        "border-focus": { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "text":         { "$type": "color", "$value": "{primitive.color.gray.100}" },
        "placeholder":  { "$type": "color", "$value": "rgba(237,236,237,0.4)" }
      },
      "light": {
        "bg":           { "$type": "color", "$value": "{primitive.color.white}" },
        "border":       { "$type": "color", "$value": "rgba(6,7,36,0.12)" },
        "border-focus": { "$type": "color", "$value": "{primitive.color.orange.500}" },
        "text":         { "$type": "color", "$value": "{primitive.color.navy.800}" },
        "placeholder":  { "$type": "color", "$value": "{primitive.color.gray.400}" }
      },
      "radius":     { "$type": "dimension", "$value": "{primitive.radius.md}" },
      "px":         { "$type": "dimension", "$value": "{primitive.spacing.4}" },
      "py":         { "$type": "dimension", "$value": "{primitive.spacing.3}" },
      "font-size":  { "$type": "dimension", "$value": "{primitive.font.size.base}" }
    },

    "badge": {
      "radius": { "$type": "dimension", "$value": "{primitive.radius.full}" },
      "px":     { "$type": "dimension", "$value": "{primitive.spacing.3}" },
      "py":     { "$type": "dimension", "$value": "{primitive.spacing.1}" },
      "font-size":   { "$type": "dimension", "$value": "{primitive.font.size.xs}" },
      "font-weight": { "$type": "fontWeight", "$value": "{primitive.font.weight.semibold}" },
      "variants": {
        "default": { "bg": { "$type": "color", "$value": "rgba(255,103,0,0.12)" }, "text": { "$type": "color", "$value": "{primitive.color.orange.400}" } },
        "navy":    { "bg": { "$type": "color", "$value": "rgba(6,7,36,0.12)" }, "text": { "$type": "color", "$value": "{primitive.color.navy.400}" } },
        "success": { "bg": { "$type": "color", "$value": "rgba(16,185,129,0.12)" }, "text": { "$type": "color", "$value": "{primitive.color.success}" } }
      }
    },

    "glass": {
      "bg":     { "$type": "color", "$value": "rgba(6,7,36,0.6)" },
      "blur":   { "$type": "dimension", "$value": "20px" },
      "border": { "$type": "color", "$value": "rgba(237,236,237,0.08)" }
    }
  }
}
