Options -Indexes

# ============================================================================
# FORZA UTF-8 CHARSET (TRIPLO LAYER - MASSIMA COMPATIBILITÀ)
# ============================================================================

# Layer 1: AddDefaultCharset (base Apache)
AddDefaultCharset UTF-8

# Layer 2: AddCharset esplicito per ogni estensione
<IfModule mod_mime.c>
    AddCharset UTF-8 .html .htm .txt .css .js .json .xml .svg
</IfModule>

# Layer 3: Header HTTP Content-Type (se mod_headers disponibile)
<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm|txt|css|js|json|xml)$">
        Header set Content-Type "text/html; charset=UTF-8"
    </FilesMatch>
</IfModule>

# ============================================================================
# CONFIGURAZIONE SITO
# ============================================================================

# Block direct PHP access (legacy Altervista files)
<FilesMatch "\.php$">
  Order Deny,Allow
  Deny from all
</FilesMatch>

RewriteEngine On

# Skip rewrite for static assets AND content paths
RewriteCond %{REQUEST_URI} ^/(_next|images|fonts|api|404|en|it)(/|$) [NC]
RewriteRule ^ - [L]

# 301 redirect: root → Italian locale
RewriteRule ^$ /it/ [R=301,L]

# Directory index
DirectoryIndex index.html
