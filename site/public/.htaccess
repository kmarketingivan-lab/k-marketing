Options -Indexes

# Forza charset UTF-8 nell'header HTTP per tutti i file
# Necessario perché Altervista di default non dichiara charset,
# causando la lettura errata dei caratteri accentati (Ã¨ invece di è)
AddDefaultCharset UTF-8

# Block direct PHP access (legacy Altervista files)
<FilesMatch "\.php$">
  Order Deny,Allow
  Deny from all
</FilesMatch>

RewriteEngine On

# Skip rewrite for static assets
RewriteCond %{REQUEST_URI} ^/(_next|images|fonts|api|404|en)(/|$) [NC]
RewriteRule ^ - [L]

# 301 redirect: root → Italian locale (real HTTP redirect, not meta refresh)
RewriteRule ^$ /it/ [R=301,L]
